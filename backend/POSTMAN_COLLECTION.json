{
  "info": {
    "name": "Jooblie API",
    "description": "REST API for Jooblie Job Portal",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api/v1"
    },
    {
      "key": "access_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jobseeker@example.com\",\n  \"password\": \"password123\",\n  \"full_name\": \"John Doe\",\n  \"user_type\": \"job_seeker\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jobseeker@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Get All Jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/jobs?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["jobs"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "search",
                  "value": "Flutter",
                  "disabled": true
                },
                {
                  "key": "location",
                  "value": "Remote",
                  "disabled": true
                },
                {
                  "key": "job_type",
                  "value": "full-time",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Get Job by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/jobs/:jobId",
              "host": ["{{base_url}}"],
              "path": ["jobs", ":jobId"],
              "variable": [
                {
                  "key": "jobId",
                  "value": "job-id-here"
                }
              ]
            }
          }
        },
        {
          "name": "Get Similar Jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/jobs/:jobId/similar?limit=5",
              "host": ["{{base_url}}"],
              "path": ["jobs", ":jobId", "similar"],
              "query": [
                {
                  "key": "limit",
                  "value": "5"
                }
              ],
              "variable": [
                {
                  "key": "jobId",
                  "value": "job-id-here"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "Apply for Job",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cover_letter\": \"I am very interested in this position and believe my skills align perfectly with the requirements...\",\n  \"resume_url\": \"https://example.com/resume.pdf\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/applications/jobs/:jobId/apply",
              "host": ["{{base_url}}"],
              "path": ["applications", "jobs", ":jobId", "apply"],
              "variable": [
                {
                  "key": "jobId",
                  "value": "job-id-here"
                }
              ]
            }
          }
        },
        {
          "name": "Get My Applications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/applications?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["applications"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "status",
                  "value": "applied",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Get Application by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/applications/:applicationId",
              "host": ["{{base_url}}"],
              "path": ["applications", ":applicationId"],
              "variable": [
                {
                  "key": "applicationId",
                  "value": "application-id-here"
                }
              ]
            }
          }
        },
        {
          "name": "Withdraw Application",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/applications/:applicationId",
              "host": ["{{base_url}}"],
              "path": ["applications", ":applicationId"],
              "variable": [
                {
                  "key": "applicationId",
                  "value": "application-id-here"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    }
  ]
}
